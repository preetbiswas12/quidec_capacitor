rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(handle) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(handle))
        && request.auth.uid == get(/databases/$(database)/documents/users/$(handle)).data.uid;
    }

    function isExistingUser(handle) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(handle));
    }

    function isOwner(userId) {
      return isUser(userId);
    }

    function isOwnerByPath(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;

      match /settings/{settingDoc} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /chatSettings/{chatId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /callHistory/{callId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /deviceSessions/{deviceId} {
        allow read, write, delete: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /syncRequests/{requestId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /linkedDevices/{deviceId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /notifications/{notifId} {
        allow read, write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }

      match /statuses/{statusId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SYSTEM CONFIG — Admin only (read-only for users)
    // ═══════════════════════════════════════════════════════════════════════

    match /users/system_config {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /friendships/system_meta {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /conversations/system_meta {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FRIENDSHIPS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /friendships/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isExistingUser(userId) || isOwnerByPath(userId));
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (isOwner(userId) || isOwnerByPath(userId));
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FRIEND REQUESTS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && (isUser(request.resource.data.fromUid) || request.auth.uid == request.resource.data.fromUid)
        && request.resource.data.toUid != request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CONVERSATIONS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════
    // Conversation IDs are "{handle1}_{handle2}" where handles may contain
    // underscores (e.g. "preet_4736_preetb_4711"). We use the participants
    // array stored in the document instead of splitting the ID.

    match /conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated();
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // GROUPS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (isUser(resource.data.creatorId) || request.auth.uid == resource.data.creatorId);
      allow delete: if isAuthenticated()
        && (isUser(resource.data.creatorId) || request.auth.uid == resource.data.creatorId);

      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CALLS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /calls/{callId} {
      allow read: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
        || request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId
      );
      allow create: if isAuthenticated()
        && (isUser(request.resource.data.callerId) || request.auth.uid == request.resource.data.callerId);
      allow update: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
        || request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId
      );
      allow delete: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
        || request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // MEDIA CHUNKS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /mediaChunks/{chunkId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAuthenticated() && (
        isUser(resource.data.metadata.uploadedBy)
        || isUser(resource.data.metadata.intendedFor)
        || request.auth.uid == resource.data.metadata.uploadedBy
        || request.auth.uid == resource.data.metadata.intendedFor
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
