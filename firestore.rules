rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(handle) {
      return request.auth.uid == get(/databases/$(database)/documents/users/$(handle)).data.uid;
    }

    function isOwner(userId) {
      return request.auth.uid == get(/databases/$(database)/documents/users/$(userId)).data.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;

      match /settings/{settingDoc} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /chatSettings/{chatId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /callHistory/{callId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /deviceSessions/{deviceId} {
        allow read, write, delete: if isAuthenticated() && isOwner(userId);
      }

      match /syncRequests/{requestId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /linkedDevices/{deviceId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      match /statuses/{statusId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // SYSTEM CONFIG — Admin only (read-only for users)
    // ═══════════════════════════════════════════════════════════════════════

    match /users/system_config {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /friendships/system_meta {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /conversations/system_meta {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FRIENDSHIPS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /friendships/{userId} {
      allow read, write: if isAuthenticated()
        && isUser(userId);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FRIEND REQUESTS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (
        isUser(resource.data.fromUid) || isUser(resource.data.toUid)
      );
      allow create: if isAuthenticated()
        && isUser(request.resource.data.fromUid)
        && request.resource.data.toUid != request.auth.uid;
      allow update: if isAuthenticated() && (
        isUser(resource.data.fromUid) || isUser(resource.data.toUid)
      );
      allow delete: if isAuthenticated() && (
        isUser(resource.data.fromUid) || isUser(resource.data.toUid)
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CONVERSATIONS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() && (
        isUser(conversationId.split('_')[0])
        || isUser(conversationId.split('_')[1])
      );

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (
          isUser(conversationId.split('_')[0])
          || isUser(conversationId.split('_')[1])
        );
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // GROUPS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && isUser(resource.data.creatorId);
      allow delete: if isAuthenticated()
        && isUser(resource.data.creatorId);

      // Group messages: authenticated members can read.
      // Membership is enforced client-side and by the group document's members array.
      // Server-side: any authenticated user who can read the group can read/write messages.
      match /messages/{messageId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CALLS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /calls/{callId} {
      allow read: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
      );
      allow create: if isAuthenticated()
        && isUser(request.resource.data.callerId);
      allow update: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
      );
      allow delete: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // MEDIA CHUNKS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /mediaChunks/{chunkId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAuthenticated() && (
        isUser(resource.data.metadata.uploadedBy)
        || isUser(resource.data.metadata.intendedFor)
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
