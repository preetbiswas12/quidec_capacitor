rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User Avatars: Publicly readable for friends, but only owner can upload
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Encrypted Media Chunks: Secured to authenticated users
    // Since chunks are AES-256 encrypted on the device before upload,
    // they are secure even in the cloud.
    match /media/chunks/{fileId} {
      allow read, write: if request.auth != null;
    }

    match /media/metadata/{fileId} {
      allow read, write: if request.auth != null;
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
