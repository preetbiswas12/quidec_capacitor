rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // All paths require authentication by default
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Media uploads: authenticated, capped at 10 MB, image/video/audio types only
    match /media/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*|audio/.*');
    }

    // Chat / conversation attachments
    match /chats/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // User avatars: owners write, any authenticated user reads
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
