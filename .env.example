# # ============================================================================
# # QUIDEC APP - ENVIRONMENT CONFIGURATION
# # For Capacitor Android Build & Web Development
# # ============================================================================

# # ============================================================================
# # SERVER CONFIGURATION
# # ============================================================================

# # WebSocket server (for Android, use your actual IP or deployed domain)
# # Development: ws://192.168.1.100:3000 (use your local IP)
# # Production: wss://your-server.com
# VITE_SERVER_URL=wss://quidec-server.onrender.com

# # PeerJS Server Configuration
# # By default uses cloud.peerjs.com (free, reliable)
# # Leave commented out unless you have a custom self-hosted PeerJS server
# # VITE_PEER_SERVER_HOST=your-custom-server.com
# # VITE_PEER_SERVER_PORT=9000
# # VITE_PEER_SERVER_SECURE=true
# # VITE_PEER_SERVER_KEY=your-api-key

# # ============================================================================
# # FIREBASE CONFIGURATION (Optional - for push notifications)
# # ============================================================================

# # Get these from Google Firebase Console
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# # ============================================================================
# # CAPACITOR/ANDROID CONFIGURATION
# # ============================================================================
# # Package name (also in capacitor.config.ts)
# VITE_PACKAGE_NAME=com.quidec.chat

# # App name for Android
# VITE_APP_NAME=Quidec Chat

# # App version (sync with capacitor.config.ts and Android gradle)
# VITE_APP_VERSION=1.0.0

# # ============================================================================
# # DEVELOPMENT MODE FLAGS
# # ============================================================================

# # Enable debug logging
# VITE_DEBUG=false

# # Allow WebSocket cleartext (http://) in development
# # WARNING: Only for development! Set to false in production
# VITE_ALLOW_CLEARTEXT=true

# # ============================================================================
# # SENTRY ERROR MONITORING (Production)
# # ============================================================================

# # Sentry DSN for error monitoring and crash reporting
# # Get from: https://sentry.io/
# # Leave empty to disable error monitoring
# VITE_SENTRY_DSN=

# # Environment name (development, staging, production)
# VITE_ENVIRONMENT=development

# # ============================================================================
# # TURN SERVER CREDENTIALS (ExpressTURN)
# # ============================================================================

# # Get from: https://expressturn.com/
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=

