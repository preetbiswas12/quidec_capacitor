/**
 * Firestore Security Rules
 * Deploy these rules in Firebase Console -> Firestore Database -> Rules
 *
 * These rules ensure:
 * - Users can only read/write their own data
 * - Friends can access conversations
 * - Messages are properly protected
 * - Notifications are user-specific
 *
 * IMPORTANT: User documents use CUSTOM HANDLES as doc IDs (e.g. "johndoe1234"),
 * NOT Firebase Auth UIDs. The `uid` field inside each user document stores the
 * actual Firebase Auth UID. All ownership checks must resolve handles -> auth UIDs.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    /**
     * Resolve a custom handle to the Firebase Auth UID stored in that user's
     * document.
     */
    function authUidForHandle(handle) {
      return get(/databases/$(database)/documents/users/$(handle)).data.uid;
    }

    /**
     * Check whether the currently authenticated user "owns" the given handle.
     */
    function isUser(handle) {
      return request.auth.uid == authUidForHandle(handle);
    }

    // Check ownership via the parent user document — resolves custom handle → auth UID.
    // Used for subcollection rules under users/{handle}.
    function isOwner(userId) {
      return request.auth.uid == get(/databases/$(database)/documents/users/$(userId)).data.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /users/{handle} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
        && (
          (resource.data.uid == request.auth.uid)
          || (request.resource.data.uid == request.auth.uid)
        );

      // Nested notifications subcollection
      match /notifications/{notificationId} {
        allow read, write, delete: if isAuthenticated() && isOwner(handle);
      }

      // Nested call history subcollection (private to owner)
      match /callHistory/{callId} {
        allow read, write, delete: if isAuthenticated() && isOwner(handle);
      }

      // Nested statuses subcollection (visible to all authenticated, writable by owner)
      match /statuses/{statusId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && isOwner(handle);
      }

      // Nested settings subcollections
      match /settings/{settingId} {
        allow read, write: if isAuthenticated() && isOwner(handle);
      }

      // Nested chat settings
      match /chatSettings/{chatId} {
        allow read, write: if isAuthenticated() && isOwner(handle);
      }

      // Nested device sessions
      match /deviceSessions/{deviceId} {
        allow read, write, delete: if isAuthenticated() && isOwner(handle);
      }

      // Nested linked devices
      match /linkedDevices/{deviceId} {
        allow read, write: if isAuthenticated() && isOwner(handle);
      }

      // Nested sync requests
      match /syncRequests/{requestId} {
        allow read, write: if isAuthenticated() && isOwner(handle);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FRIENDSHIPS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /friendships/{userId} {
      // userId = custom handle (e.g. "preet.5815"), NOT auth UID
      allow read: if isAuthenticated() && isUser(userId);
      allow write: if isAuthenticated() && isUser(userId);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // FRIEND REQUESTS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (
        isUser(resource.data.fromUid) || isUser(resource.data.toUid)
      );
      allow create: if isAuthenticated()
        && isUser(request.resource.data.fromUid);
      allow update: if isAuthenticated() && (
        isUser(resource.data.fromUid) || isUser(resource.data.toUid)
      );
      allow delete: if isAuthenticated() && (
        isUser(resource.data.fromUid) || isUser(resource.data.toUid)
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CONVERSATIONS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated() && (
        isUser(conversationId.split('_')[0])
        || isUser(conversationId.split('_')[1])
      );

      // Nested messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (
          isUser(conversationId.split('_')[0])
          || isUser(conversationId.split('_')[1])
        );
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // MEDIA COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /media/{mediaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && isUser(request.resource.data.uploadedBy);
      allow delete: if isAuthenticated()
        && isUser(resource.data.uploadedBy);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CALLS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /calls/{callId} {
      allow read: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
      );
      allow create: if isAuthenticated()
        && isUser(request.resource.data.callerId);
      allow update: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
      );
      allow delete: if isAuthenticated() && (
        isUser(resource.data.callerId) || isUser(resource.data.receiverId)
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // GROUPS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && isUser(resource.data.creatorId);
      allow delete: if isAuthenticated()
        && isUser(resource.data.creatorId);

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // MEDIA CHUNKS COLLECTION
    // ═══════════════════════════════════════════════════════════════════════

    match /mediaChunks/{chunkId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAuthenticated() && (
        isUser(resource.data.metadata.uploadedBy)
        || isUser(resource.data.metadata.intendedFor)
      );
    }

    // ═══════════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
