{
  "type": "module",
  "name": "free-cluely-web",
  "version": "1.0.0",
  "description": "Free Cluely - Web version (React)",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm exec vite build",
    "preview": "vite preview",
    "build:web": "vite build",
    "sync:ios": "pnpm build:web && cap sync ios",
    "sync:android": "pnpm build:web && cap sync android",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "build:android": "pnpm build:web && cap sync android && cd android && ./gradlew assembleRelease",
    "build:android:apk": "pnpm build:web && cap sync android && cd android && ./gradlew assembleDebug",
    "build:android:aab": "pnpm build:web && cap sync android && cd android && ./gradlew bundleRelease",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "clean": "rm -rf dist node_modules && pnpm install"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^8.3.0",
