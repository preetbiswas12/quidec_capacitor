{
  "type": "module",
  "name": "octate-wee-web",
  "version": "1.3.0",
  "description": "Veill - Encrypted Real-time Messaging",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:web": "vite build",
    "sync:ios": "pnpm build:web && cap sync ios",
    "sync:android": "pnpm build:web && cap sync android",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "build:android": "pnpm build:web && cap sync android && cd android && ./gradlew assembleRelease",
    "build:android:apk": "pnpm build:web && cap sync android && cd android && ./gradlew assembleRelease",
    "build:android:aab": "pnpm build:web && cap sync android && cd android && ./gradlew bundleRelease",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "clean": "rm -rf dist node_modules && pnpm install"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.0.0",
    "@capacitor/camera": "8.0.2",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.0",
    "@capacitor/filesystem": "8.1.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-badge": "^8.0.2",
    "@sentry/react": "^10.63.0",
    "@tailwindcss/vite": "^4.3.0",
    "firebase": "^12.16.0",
    "idb": "^8.0.0",
    "lucide-react": "^0.487.0",
    "motion": "^12.38.0",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.14.2",
    "sonner": "^1.7.4",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.0.0",
    "firebase-tools": "^15.17.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}