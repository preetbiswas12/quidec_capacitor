# PeerServer Environment Configuration
# Copy this to .env.local and fill in your values

# Server Configuration
PORT=9000
HOST=localhost

# For production, use your domain
# HOST=your-domain.com
# PORT=443 (if behind reverse proxy with SSL)

# PeerJS API Key (should match client configuration)
PEERJS_KEY=quide-peer-key

# Reverse Proxy (set to true if behind nginx/apache)
PROXIED=false
